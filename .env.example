# Stripe (one mode per deployment: test keys with test prices, or live keys with live prices)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CORE=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
# Annual (yearly) base-plan price ids. Used when checkout is called with billing="annual".
# Seats are NOT billed annually - the seat item always uses STRIPE_PRICE_SEAT (monthly).
STRIPE_PRICE_CORE_ANNUAL=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_PRO_ANNUAL=
# Required for Checkout seat add-ons and Team Management seat sync (BTQ Paid Seat Monthly). No in-code default.
# STRIPE_PRICE_SEAT=price_...
STRIPE_PRICE_SEAT=

# Canonical site URL for Checkout success/cancel redirects (read by serverless billing API).
# Prefer APP_URL in production; VITE_APP_URL is still supported if APP_URL is unset.
# APP_URL=https://your-production-domain.com

# Partner Demo Mode (presentation-layer only — no backend permission changes).
# When "1" or "true", hides transaction-management-specific UI elements
# (Compliance Overview, Pending Review / Rejected counters, Documents Complete
# column, Finalize buttons, checklist completion statuses) and relabels the
# Transactions nav entry to "Operations" so BTQ shows up as a brokerage
# operations / orchestration platform during vendor partnership demos. Can
# also be toggled at runtime via `?partner_demo=1` in the URL or
# `window.__btqSetPartnerDemoMode(true)` in the browser console.
# VITE_PARTNER_DEMO_MODE=0
